DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# For NextAuth.js (generate with `openssl rand -base64 32`) - Keep this if you might switch back
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET"
NEXTAUTH_URL="http://localhost:9002" # Your app's base URL

# For Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_YOUR_SECRET_KEY"

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Set to true to use mock data in src/lib/products.ts instead of hitting the database
# Useful for Firebase Studio if Prisma direct connection has issues
# For local development, this should typically be false or not set.
USE_MOCK_DATA=false

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Clerk API Keys - Get these from your Clerk Dashboard (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE"
CLERK_SECRET_KEY="sk_test_YOUR_CLERK_SECRET_KEY_HERE"

# Clerk URLs (Optional - Clerk usually infers these, but can be set for explicitness)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# NextAuth.js (Keep for reference if you switch, but ensure it's a strong secret if used)
# Generate one here: https://generate-secret.vercel.app/32 or run `openssl rand -base64 32`
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET_HERE"
NEXTAUTH_URL="http://localhost:9002" # Your app's base URL


# Clerk API Keys - Get these from your Clerk Dashboard (https://dashboard.clerk.com/)
# Replace with your actual keys!
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_WITH_YOUR_REAL_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_REAL_SECRET_KEY"

# Your Database Connection String (e.g., from Neon, Supabase, local PostgreSQL)
# Example: DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"
DATABASE_URL="YOUR_DATABASE_CONNECTION_STRING_HERE"

# NextAuth.js (if you were to use it - keep for reference or future use)
# NEXTAUTH_URL="http://localhost:9002" # Or your production URL
# NEXTAUTH_SECRET="YOUR_STRONG_NEXTAUTH_SECRET_HERE" # Generate with: openssl rand -base64 32

# Optional: Flag to use mock data (primarily for environments where Prisma might have issues)
# Set to "true" to use mock data, "false" or leave unset to use Prisma.
USE_MOCK_DATA="false"

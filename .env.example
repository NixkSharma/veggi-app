# Clerk Environment Variables
# Get these from your Clerk Dashboard: https://dashboard.clerk.com/ -> Your Application -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_WITH_YOUR_REAL_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_REAL_SECRET_KEY"

# Clerk URLs - These are often managed by Clerk automatically but can be set if needed.
# Refer to Clerk documentation for when to override these.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Database URL (e.g., for PostgreSQL)
# Replace with your actual database connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Optional: For using mock data if USE_MOCK_DATA_FLAG is true in products.ts
# Set to "true" to use mock data, "false" or leave unset to use Prisma.
# USE_MOCK_DATA="false"

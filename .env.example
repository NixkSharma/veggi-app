
# Clerk API Keys - Get these from your Clerk Dashboard (https://dashboard.clerk.com/)
# Replace with your actual keys!
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_WITH_YOUR_REAL_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_REAL_SECRET_KEY"

# NextAuth.js (if you were to use it, keep for reference or remove if not needed)
# NEXTAUTH_URL="http://localhost:9002" # Or your production URL
# NEXTAUTH_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET_HERE" # Generate with: openssl rand -base64 32

# Database URL (if using Prisma directly without Accelerate)
# Replace with your actual database connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Optional: For using mock data in src/lib/products.ts (primarily for Firebase Studio)
# Set to "true" to use mock data, "false" or remove to use Prisma.
USE_MOCK_DATA="false"


# Clerk API Keys (replace with your actual keys from Clerk.com dashboard)
# You can get these from your Clerk dashboard: https://dashboard.clerk.com/ -> Your Application -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_WITH_YOUR_REAL_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_REAL_SECRET_KEY"

# Clerk URLs (these are usually the defaults but can be customized if needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# NextAuth.js (if you were using it, keep for reference or remove if solely Clerk)
# Generate a new secret: openssl rand -base64 32
# NEXTAUTH_SECRET="dummysecretforinitialsetupgeneratenewone"
# NEXTAUTH_URL="http://localhost:9002" # Your app's base URL

# Database URL (replace with your actual database connection string)
# Example for PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DATABASE_URL="postgresql://neondb_owner:npg_LpAW1VmXv2eZ@ep-lively-poetry-a4tyobnx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Optional: Set to true to use mock data for products/categories

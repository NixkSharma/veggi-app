
# Clerk Environment Variables
# Get these from your Clerk Dashboard: https://dashboard.clerk.com/
# IMPORTANT: NEXT_PUBLIC_ variables are exposed to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_WITH_YOUR_REAL_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_REPLACE_WITH_YOUR_REAL_SECRET_KEY"

# NextAuth.js (if you were to use it in parallel or switch, keep for reference)
# You can generate a secret using: openssl rand -base64 32
# NEXTAUTH_SECRET="dummysecretforinitialsetupgeneratenewone"
# NEXTAUTH_URL="http://localhost:9002" # Replace with your app's URL in production

# Database URL (for Prisma)
# Replace with your actual database connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Mock Data Flag (for development/testing in restricted environments)
# USE_MOCK_DATA=false
